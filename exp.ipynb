   "source": [
    "from Src.Embedding.embedding import GPTEmbeddings\n",
    "import torch\n",
    "\n",
    "x = torch.randint(\n",
    "    0,\n",
    "    100,\n",
    "    (4, 16)\n",
    ")\n",
    "\n",
    "emb = GPTEmbeddings(\n",
    "    vocab_size=100,\n",
    "    embed_dim=64,\n",
    "    block_size=16\n",
    ")\n",
    "\n",
    "out = emb(x)\n",
    "\n",
    "print(out.shape)"
   ]
